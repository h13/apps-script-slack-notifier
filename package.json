{
  "name": "apps-script-slack-notifier",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && pnpm run bundle && cp appsscript.json dist/appsscript.json",
    "bundle": "rollup --no-treeshake -c rollup.config.mjs",
    "check": "pnpm run lint && pnpm run lint:css && pnpm run lint:html && pnpm run typecheck && pnpm run test",
    "clean": "rimraf build dist",
    "deploy": "pnpm run check && pnpm run build && cp .clasp-dev.json .clasp.json && clasp push -f",
    "deploy:prod": "pnpm run check && pnpm run build && cp .clasp-prod.json .clasp.json && clasp push",
    "format": "oxfmt --write .",
    "lint": "oxlint --fix src/ test/",
    "lint:css": "stylelint --allow-empty-input '**/*.{css,scss,html}'",
    "lint:html": "htmlhint --ignore 'coverage/**,dist/**' '**/*.html'",
    "prepare": "husky",
    "test": "jest test/ --passWithNoTests --detectOpenHandles --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@google/clasp": "3.3.0",
    "@types/google-apps-script": "2.0.11",
    "@types/jest": "30.0.0",
    "htmlhint": "1.9.2",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.1.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "postcss-html": "1.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-cleanup": "3.2.1",
    "rollup-plugin-typescript2": "0.37.0",
    "stylelint": "17.14.1",
    "stylelint-config-standard": "40.0.0",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.34.5",
  "pnpm": {
    "overrides": {
      "diff": ">=8.0.3"
    }
  }
}
